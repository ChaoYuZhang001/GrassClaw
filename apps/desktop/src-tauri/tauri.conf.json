{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GrassClaw",
  "version": "1.0.0-beta.1",
  "identifier": "com.grassclaw.app",
  "build": {
    "beforeDevCommand": "node ../../../scripts/dev-server.mjs --host 0.0.0.0 --port 4173",
    "beforeBuildCommand": "node ../../../scripts/build-web.mjs",
    "devUrl": "http://localhost:4173/apps/web/",
    "frontendDist": "../../../dist/apps/web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      { "label": "main", "title": "GrassClaw", "width": 1280, "height": 860, "resizable": true, "fullscreen": false }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico", "icons/icon.icns"]
  }
}
